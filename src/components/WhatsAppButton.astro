---
/**
 * WhatsAppButton — botón flotante global (abajo a la derecha).
 * Enlace wa.me con mensaje por defecto pre-llenado. Ref: CLAUDE.md §6.
 */
import { whatsappLink, wa, waTooltip } from "../data/site.ts";

const href = whatsappLink(wa.default);
---

<a
  class="wa-button"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={waTooltip}
>
  <span class="wa-button__tooltip">{waTooltip}</span>
  <svg
    class="wa-button__icon"
    viewBox="0 0 32 32"
    width="28"
    height="28"
    aria-hidden="true"
    focusable="false"
  >
    <path
      fill="currentColor"
      d="M16.04 4C9.43 4 4.06 9.37 4.06 15.98c0 2.11.55 4.17 1.6 5.99L4 28l6.2-1.62a11.9 11.9 0 0 0 5.83 1.49h.01c6.6 0 11.98-5.37 11.98-11.98C28.02 9.37 22.65 4 16.04 4Zm0 21.84h-.01a9.9 9.9 0 0 1-5.04-1.38l-.36-.21-3.68.96.98-3.59-.24-.37a9.86 9.86 0 0 1-1.51-5.27c0-5.46 4.45-9.9 9.92-9.9 2.65 0 5.13 1.03 7 2.9a9.84 9.84 0 0 1 2.9 7c0 5.46-4.45 9.91-9.92 9.91Zm5.44-7.42c-.3-.15-1.76-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.07 2.88 1.22 3.08.15.2 2.1 3.21 5.08 4.5.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.69.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35Z"
    ></path>
  </svg>
</a>

<style>
  .wa-button {
    position: fixed;
    right: clamp(1rem, 4vw, 2rem);
    bottom: clamp(1rem, 4vw, 2rem);
    z-index: 200;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--color-bronce);
    color: var(--color-marfil);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--color-tinta) 22%, transparent);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .wa-button:hover {
    color: var(--color-marfil);
    background: var(--color-oro);
    transform: translateY(-2px);
  }

  .wa-button__tooltip {
    position: absolute;
    right: calc(100% + 0.75rem);
    white-space: nowrap;
    background: var(--color-tinta);
    color: var(--color-marfil);
    font-size: var(--fs-small);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    opacity: 0;
    transform: translateX(6px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .wa-button:hover .wa-button__tooltip,
  .wa-button:focus-visible .wa-button__tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* En pantallas pequeñas ocultamos el tooltip (el botón basta) */
  @media (max-width: 600px) {
    .wa-button__tooltip {
      display: none;
    }
  }
</style>
