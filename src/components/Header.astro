---
/**
 * Header — sticky, wordmark a la izquierda, navegación a la derecha.
 * Menú móvil: hamburguesa CSS-only (checkbox), sin JS. Ref: CLAUDE.md §5, §6.
 */
import { nav } from "../data/site.ts";

// Para marcar el enlace activo (aria-current)
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="wordmark" aria-label="Joyería Central Oro — inicio">
      <span class="wordmark-name">Central Oro</span>
      <span class="wordmark-tag">JOYERÍA · TEMUCO · DESDE 1995</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Abrir o cerrar el menú de navegación" />
    <label for="nav-toggle" class="nav-burger" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <nav class="nav" aria-label="Navegación principal">
      <ul class="nav__list">
        {
          nav.map((item) => {
            const href = item.href.replace(/\/$/, "") || "/";
            const isActive = href === pathname;
            return (
              <li>
                <a
                  href={item.href}
                  class="nav__link"
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-marfil);
    border-bottom: 1px solid color-mix(in srgb, var(--color-oro) 30%, transparent);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 4.75rem;
  }

  /* ---- Wordmark ---- */
  .wordmark {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
  }
  .wordmark:hover {
    color: inherit;
  }
  .wordmark-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.6rem;
    color: var(--color-tinta);
  }
  .wordmark-tag {
    margin-top: 0.35rem;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.625rem;
    letter-spacing: 0.36em;
    /* el tracking añade espacio a la derecha; compensamos */
    text-indent: 0.36em;
    color: var(--color-arena);
  }

  /* ---- Navegación ---- */
  .nav__list {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
  }
  .nav__link {
    font-size: var(--fs-small);
    font-weight: 500;
    color: var(--color-bronce);
    padding-block: 0.25rem;
    position: relative;
  }
  .nav__link[aria-current="page"] {
    color: var(--color-tinta);
  }
  .nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--color-oro);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav__link:hover::after,
  .nav__link[aria-current="page"]::after {
    transform: scaleX(1);
  }

  /* ---- Hamburguesa (oculta en desktop) ---- */
  .nav-toggle {
    display: none; /* en desktop no existe ni recibe foco */
  }
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    cursor: pointer;
  }
  .nav-burger span {
    display: block;
    height: 1.5px;
    width: 1.5rem;
    background: var(--color-tinta);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* ---- Móvil ---- */
  @media (max-width: 820px) {
    /* Checkbox invisible pero enfocable y clickeable, superpuesto a la hamburguesa */
    .nav-toggle {
      display: block;
      position: absolute;
      top: 1.125rem;
      right: clamp(1.25rem, 5vw, 3rem);
      width: 2.5rem;
      height: 2.5rem;
      margin: 0;
      opacity: 0;
      cursor: pointer;
      z-index: 2;
    }
    .nav-toggle:focus-visible + .nav-burger {
      outline: 2px solid var(--color-oro);
      outline-offset: 4px;
    }
    .nav-burger {
      display: flex;
    }
    .nav {
      position: fixed;
      inset: 4.75rem 0 auto 0;
      background: var(--color-marfil);
      border-bottom: 1px solid color-mix(in srgb, var(--color-oro) 30%, transparent);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 0.5rem clamp(1.25rem, 5vw, 3rem) 1.5rem;
    }
    .nav__list li {
      width: 100%;
    }
    .nav__link {
      display: block;
      width: 100%;
      padding: 0.85rem 0;
      font-size: var(--fs-body);
      border-bottom: 1px solid color-mix(in srgb, var(--color-oro) 15%, transparent);
    }
    .nav__link::after {
      display: none;
    }

    /* Estado abierto */
    .nav-toggle:checked ~ .nav {
      max-height: 80vh;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) {
      transform: translateY(6.5px) rotate(45deg);
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) {
      transform: translateY(-6.5px) rotate(-45deg);
    }
  }
</style>
